#!/usr/bin/env python3
"""Update the upstream tree-sitter grammar submodule for a given language.

Resolves the submodule at lang/semgrep-grammars/src/tree-sitter-<lang>, fetches
from origin, and checks out the requested ref (default: the remote default
branch). Then stages the bump, runs `lang/test-lang <lang>`, and finally
`lang/release <lang> --branch $USER/update-<lang>-<short-sha>`.
"""

from __future__ import annotations

import argparse
import getpass
import shlex
import subprocess
import sys
from pathlib import Path
from typing import NoReturn

# Map from a language's lang/ folder name to its tree-sitter-<name> submodule
# directory when the two differ.
SUBMODULE_ALIASES = {
    "gomod": "go-mod",
    "apex": "sfapex",
}

# Map from a `languages-*` entry (the name passed to test-lang) to the
# dialects it expands to in `language-variants-*` (the names passed to
# release). Kept in sync with the hardcoded cases in lang/test-lang.
LANGUAGE_VARIANTS = {
    "typescript": ["typescript", "tsx"],
    "php": ["php", "php-only"],
    "sfapex": ["apex"],
}

# Fallback default branches to try when `origin/HEAD` isn't set on the clone.
DEFAULT_BRANCH_FALLBACKS = ("origin/main", "origin/master")


def die(msg: str) -> NoReturn:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def run(cmd: list[str | Path], cwd: Path, *, capture: bool = False) -> str:
    """Run a subprocess, raising on non-zero. Returns stdout when captured."""
    print(f"$ {shlex.join(str(c) for c in cmd)}  (in {cwd})", file=sys.stderr)
    result = subprocess.run(
        cmd,
        cwd=cwd,
        check=True,
        text=True,
        stdout=subprocess.PIPE if capture else None,
    )
    return (result.stdout or "").strip()


def repo_root() -> Path:
    return Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            check=True, text=True, capture_output=True,
        ).stdout.strip()
    )


def resolve_submodule(root: Path, lang: str) -> Path:
    base = root / "lang" / "semgrep-grammars" / "src"
    candidates = language_candidates(lang)
    for name in candidates:
        path = base / f"tree-sitter-{name}"
        if path.is_dir():
            return path
    available = sorted(
        p.name.removeprefix("tree-sitter-")
        for p in base.glob("tree-sitter-*")
        if p.is_dir()
    )
    die(
        f"no submodule found for language '{lang}'.\n"
        f"  tried: {', '.join(candidates)}\n"
        f"  available: {', '.join(available)}"
    )


def default_remote_ref(submodule: Path) -> str:
    """Return the ref a plain `git pull` would track, with fallbacks."""
    try:
        return run(
            ["git", "symbolic-ref", "--short", "refs/remotes/origin/HEAD"],
            cwd=submodule, capture=True,
        )
    except subprocess.CalledProcessError:
        pass
    for ref in DEFAULT_BRANCH_FALLBACKS:
        try:
            run(["git", "rev-parse", "--verify", "--quiet", ref],
                cwd=submodule, capture=True)
            return ref
        except subprocess.CalledProcessError:
            continue
    die(
        f"could not determine the default remote branch in {submodule}; "
        f"pass --ref explicitly."
    )


def short_sha(submodule: Path, sha: str) -> str:
    return run(["git", "rev-parse", "--short", sha], cwd=submodule, capture=True)

def discover_version_files(root: Path, prefix: str) -> dict[str, Path]:
    """Map tree-sitter version (e.g., '0.22.6') to its `<prefix>-<version>` file."""
    versions: dict[str, Path] = {}
    for path in sorted((root / "lang").glob(f"{prefix}-*")):
        if path.name.endswith(".readme"):
            continue
        versions[path.name.removeprefix(f"{prefix}-")] = path
    return versions


def read_languages_entries(path: Path) -> set[str]:
    return {line for line in path.read_text().splitlines() if line.strip()}


def write_sorted_languages_entries(path: Path, entries: set[str]) -> None:
    path.write_text("\n".join(sorted(entries)) + "\n")


def languages_list_name(lang: str, root: Path) -> str:
    """Return the name to use in languages-* (suitable for test-lang)."""
    alias = SUBMODULE_ALIASES.get(lang, lang)
    semgrep_dir = (
        root / "lang" / "semgrep-grammars" / "src" / f"semgrep-{alias}"
    )
    if semgrep_dir.is_dir():
        return alias
    return lang


def language_candidates(lang: str) -> list[str]:
    return list(dict.fromkeys([lang, SUBMODULE_ALIASES.get(lang, lang)]))


def sync_membership(names: list[str], version: str,
                    version_files: dict[str, Path], root: Path) -> None:
    """Ensure each name appears in version_files[version] and nowhere else."""
    expected = version_files[version]
    expected_entries = read_languages_entries(expected)
    other_files = [p for p in version_files.values() if p != expected]

    for name in names:
        if name in expected_entries:
            print(f"'{name}' already listed in {expected.relative_to(root)}")
        else:
            expected_entries.add(name)
            print(f"Added '{name}' to {expected.relative_to(root)}")

        # Defensively remove from other version files.
        for path in other_files:
            entries = read_languages_entries(path)
            if name in entries:
                entries.remove(name)
                write_sorted_languages_entries(path, entries)
                print(f"Removed '{name}' from {path.relative_to(root)}")

    write_sorted_languages_entries(expected, expected_entries)


def check_languages_membership(root: Path, lang: str, version: str,
                               version_files: dict[str, Path],
                               variant_version_files: dict[str, Path]) -> None:
    """Ensure lang and its variants are listed in the right files."""
    lang = languages_list_name(lang, root)
    sync_membership([lang], version, version_files, root)
    variants = LANGUAGE_VARIANTS.get(lang, [lang])
    sync_membership(variants, version, variant_version_files, root)


def remove_stale_parsers(root: Path, lang: str) -> None:
    """Delete generated parser.c files so the build regenerates them.

    Why: the per-grammar Makefiles only regenerate src/parser.c when
    grammar.js is newer than parser.c. Bumping the upstream submodule
    changes tree-sitter-<lang>/grammar.js (a transitive require) without
    touching our grammar.js mtime, leaving a stale parser.c that produces
    wrong parse trees in tests.
    """
    sg_src = root / "lang" / "semgrep-grammars" / "src"
    targets = [root / "lang" / lang / "src" / "parser.c"] + [
        sg_src / f"semgrep-{name}" / "src" / "parser.c"
        for name in language_candidates(lang)
    ]
    for path in targets:
        if path.exists():
            print(f"Removing stale parser to force regeneration: "
                  f"{path.relative_to(root)}", file=sys.stderr)
            path.unlink()


def require_clean_worktree(root: Path) -> None:
    """Abort if the working tree has any pre-existing changes.

    Why: the script later runs `git add -A` to stage everything the
    update produced. If the tree was already dirty, we'd commit the
    user's unrelated WIP. `lang/release` also requires a clean tree —
    failing here is faster and gives a clearer error.
    """
    status = run(["git", "status", "--porcelain"], cwd=root, capture=True)
    if status:
        die(
            "working tree is not clean. Commit or stash changes before "
            "running update-grammar, or pass --dry-run.\n"
            f"{status}"
        )


def parse_args(version_choices: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Update a tree-sitter grammar submodule and run the "
                    "downstream test-lang / release scripts.",
    )
    parser.add_argument(
        "language",
        help="Language name (matches lang/semgrep-grammars/src/tree-sitter-<lang>).",
    )
    parser.add_argument(
        "tree_sitter_version",
        choices=version_choices,
        metavar="tree-sitter-version",
        help="Tree-sitter version the language targets. Must match one of the "
             "lang/languages-<version> files. "
             f"Choices: {', '.join(version_choices)}.",
    )
    parser.add_argument(
        "--ref",
        help="Branch, tag, or commit to check out (default: remote HEAD).",
    )
    parser.add_argument(
        "--fetch",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Run 'git fetch' in the submodule before resolving the ref.",
    )
    parser.add_argument(
        "-n", "--dry-run",
        action="store_true",
        help="Run everything up to but not including 'lang/release'.",
    )
    return parser.parse_args()


def update_submodule(args: argparse.Namespace, root: Path) -> tuple[Path, str]:
    """Check out the requested ref. Returns (submodule_path, new_full_sha)."""
    submodule = resolve_submodule(root, args.language)
    old_sha = run(["git", "rev-parse", "HEAD"], cwd=submodule, capture=True)

    if args.fetch:
        run(["git", "fetch", "--tags", "origin"], cwd=submodule)

    target = args.ref or default_remote_ref(submodule)
    new_sha = run(["git", "rev-parse", target], cwd=submodule, capture=True)

    rel = submodule.relative_to(root)
    print(f"Submodule {rel}: {old_sha} -> {new_sha} ({target})")

    if old_sha == new_sha:
        print("Already up to date.")
        return submodule, new_sha

    run(["git", "checkout", new_sha], cwd=submodule)
    run(["git", "add", "--", rel], cwd=root)
    return submodule, new_sha


def commit_changes(root: Path, lang: str, new_short: str) -> None:
    run(["git", "add", "-A"], cwd=root)
    try:
        run(["git", "diff", "--cached", "--quiet"], cwd=root, capture=True)
    except subprocess.CalledProcessError:
        message = f"Update tree-sitter-{lang} grammar to {new_short}"
        run(["git", "commit", "-m", message], cwd=root)
        return
    print("No changes to commit.")


def main() -> int:
    root = repo_root()
    version_files = discover_version_files(root, "languages")
    if not version_files:
        die("no lang/languages-* files found.")
    variant_version_files = discover_version_files(root, "language-variants")
    missing_variants = set(version_files) - set(variant_version_files)
    if missing_variants:
        die(
            "no lang/language-variants-* file for versions: "
            f"{', '.join(sorted(missing_variants))}."
        )
    args = parse_args(list(version_files.keys()))
    if "/" in args.language:
        die("language name must not contain '/'.")

    if not args.dry_run:
        require_clean_worktree(root)

    submodule, new_sha = update_submodule(args, root)
    remove_stale_parsers(root, args.language)

    check_languages_membership(root, args.language,
                               args.tree_sitter_version,
                               version_files, variant_version_files)

    lang_dir = root / "lang"
    run(["./test-lang", args.language], cwd=lang_dir)

    new_short = short_sha(submodule, new_sha)
    branch = f"{getpass.getuser()}/update-{args.language}-{new_short}"

    release_args = ["./release", args.language, "--branch", branch]

    if args.dry_run:
        print("Dry run: stopping before " + shlex.join(release_args))
        return 0

    # `release` requires a clean git status, so commit everything the
    # update produced (submodule bump, languages-* edits, regenerated
    # parsers, deleted stale parser.c files) before invoking it.
    commit_changes(root, args.language, new_short)

    run(release_args, cwd=lang_dir)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
    except subprocess.CalledProcessError as exc:
        die(f"command failed (exit {exc.returncode}): {shlex.join(str(c) for c in exc.cmd)}")
