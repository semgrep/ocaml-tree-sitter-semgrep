#!/usr/bin/env python3
"""Propose an upstream grammar update for a single language.

This is the per-language driver behind the scheduled "propose grammar
updates" GitHub Actions workflow. It wraps `scripts/update-grammar`,
adding the orchestration that workflow needs:

  * resolve each grammar's latest *stable* release tag (never an in-flux
    upstream `master` commit),
  * bump to it via `update-grammar --skip-release` (so nothing is ever
    pushed to the downstream `semgrep-<lang>` repos),
  * regenerate the corpus snapshots a grammar bump invariably churns and
    re-run `test-lang` for an authoritative pass/fail,
  * open exactly one PR in *this* repo when there's a real, green update,
  * and clean up after itself so a failure never leaks into the next run.

It deliberately reuses `update-grammar`'s language-discovery and
version-file logic by importing it (see `_load_update_grammar`) rather
than duplicating it.

Modes:
  propose-grammar-update --list-languages [--json]
      Print the set of proposable languages (one per line, or a JSON
      array for the workflow matrix).
  propose-grammar-update <language> --resolve-tag-only
      Print the latest stable tag for <language> and exit (no mutation).
  propose-grammar-update <language> [--open-pr] [--dry-run] [--review-agent]
      Bump <language> to its latest tag, regenerate snapshots, test, and
      emit a JSON result. With --open-pr, also create the PR; --dry-run
      prints the would-be PR instead of pushing. --review-agent (explicit
      opt-in) dispatches a Cursor agent to adapt tests on a test-lang
      failure; without it a failing bump is simply reported as failed.
  propose-grammar-update <language> --release [--result FILE]
      Downstream step: release the validated parser branch to
      semgrep-<lang> via PR. semgrep-proprietary integration is left to
      the existing Cursor workflow on that repo — not handled here.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from dataclasses import asdict, dataclass, fields
from importlib.machinery import SourceFileLoader
from importlib.util import module_from_spec, spec_from_loader
from pathlib import Path
from typing import Any

###############################################################################
# update-grammar import #
###############################################################################

# `update-grammar` has no extension, so it can't be imported normally. Load it
# the same way scripts/test_update_grammar.py does and reuse its helpers
# instead of duplicating language-discovery / version-file logic.
_SCRIPT_DIR = Path(__file__).resolve().parent
_UPDATE_GRAMMAR_PATH = _SCRIPT_DIR / "update-grammar"


def _load_update_grammar() -> Any:
    """Load `scripts/update-grammar` as an importable module."""
    loader = SourceFileLoader("update_grammar", str(_UPDATE_GRAMMAR_PATH))
    spec = spec_from_loader("update_grammar", loader)
    module = module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


ug = _load_update_grammar()

###############################################################################
# Types #
###############################################################################

# Result statuses, in the JSON contract emitted on stdout:
#   updated  - submodule moved to a newer tag and test-lang passed
#   no-op    - already at the latest tag
#   no-tags  - upstream has no parseable stable release tag
#   exists   - a branch/PR already exists for this lang+tag
#   failed   - the bump or test-lang failed (human attention needed)
STATUS_UPDATED = "updated"
STATUS_NO_OP = "no-op"
STATUS_NO_TAGS = "no-tags"
STATUS_EXISTS = "exists"
STATUS_FAILED = "failed"

# A tag counts as a stable release iff it is `X.Y[.Z...]`, optionally with a
# single leading `v`. This deliberately excludes prereleases (`-rc1`, `-beta`),
# date tags, and scheme-specific names (`parser-*`) so we never propose an
# upstream version its own authors consider unstable.
_STABLE_TAG_RE = re.compile(r"^v?\d+(?:\.\d+)+$")


@dataclass(frozen=True)
class Target:
    """Everything needed to act on a language, resolved without mutating."""
    language: str
    wrapper: str
    submodule: Path
    ts_version: str | None = None
    url: str | None = None
    tag: str | None = None
    skip_reason: str | None = None


@dataclass
class Result:
    """Outcome of a propose run — the JSON contract emitted on stdout.

    Serialized to `result-<lang>.json` by the workflow's propose job and read
    back by its integrate job (`from_file`), so the release step acts on the
    exact tag/branch that was validated, never a re-resolved one.
    """
    language: str
    ts_version: str | None = None
    old_sha: str | None = None
    new_sha: str | None = None
    new_tag: str | None = None
    status: str | None = None
    detail: str | None = None
    test_log_tail: str = ""
    corpus_diff: str = ""
    tests_adapted: bool = False
    branch: str | None = None

    def to_json(self) -> str:
        return json.dumps({k: v for k, v in asdict(self).items() if v is not None})

    @classmethod
    def from_file(cls, path: Path) -> "Result":
        """Load a result artifact, ignoring keys this version doesn't know."""
        data = json.loads(path.read_text())
        known = {f.name for f in fields(cls)}
        return cls(**{k: v for k, v in data.items() if k in known})

###############################################################################
# Helpers #
###############################################################################


def log(msg: str) -> None:
    """Print a human-facing progress line to stderr (stdout is for JSON)."""
    print(msg, file=sys.stderr)


def git_query(cmd: list[str], cwd: Path) -> subprocess.CompletedProcess:
    """Run a read-only git query quietly (no command echo, never raises).

    `update-grammar`'s `run` echoes every command to stderr, which is
    noise for the many read-only probes here. Use this for queries;
    reserve `ug.run` for mutating steps where live output is wanted.
    """
    return subprocess.run(
        cmd, cwd=cwd, text=True, capture_output=True, check=False,
    )


def run_quiet(cmd: list[str], cwd: Path) -> None:
    """Run a mutating command, mirroring its output to STDERR, raising on error.

    stdout is reserved for the single JSON result line, so git/gh output
    must never go there (it would corrupt the contract and the workflow's
    `tee`'d artifact). The child's stderr is merged into its stdout at
    capture time (stderr=STDOUT) so the re-emitted log keeps the original
    interleaving.
    """
    log(f"$ {' '.join(cmd)}  (in {cwd})")
    r = subprocess.run(cmd, cwd=cwd, text=True, check=False,
                       stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    sys.stderr.write(r.stdout)
    if r.returncode != 0:
        raise subprocess.CalledProcessError(r.returncode, cmd, r.stdout)


def version_key(tag: str) -> tuple[int, ...]:
    """Sort key for a stable tag: the numeric components as an int tuple.

    `v0.25.0` -> (0, 25, 0). Used to pick the highest tag. Assumes the
    caller already filtered to `_STABLE_TAG_RE`-matching tags.
    """
    return tuple(int(part) for part in tag.lstrip("vV").split("."))


def gitmodules_url(root: Path, submodule: Path) -> str | None:
    """Return the upstream URL for `submodule`, rewritten to HTTPS.

    `.gitmodules` sections are keyed inconsistently (e.g. java's section is
    `submodule.lang/tree-sitter-java` while its path is the standard
    `lang/semgrep-grammars/src/tree-sitter-java`), so we match on the
    `path` value rather than the section name. SSH URLs (gosu,
    requirements) are rewritten to HTTPS so `git ls-remote` works without
    keys in CI.
    """
    rel = submodule.relative_to(root).as_posix()
    result = git_query(
        ["git", "config", "-f", ".gitmodules", "--get-regexp", r"\.path$"],
        cwd=root,
    )
    section = None
    for line in result.stdout.splitlines():
        key, _, path = line.partition(" ")
        if path == rel:
            section = key[: -len(".path")]
            break
    if section is None:
        return None
    url = git_query(
        ["git", "config", "-f", ".gitmodules", "--get", f"{section}.url"],
        cwd=root,
    ).stdout.strip()
    if not url:
        return None
    return url.replace("git@github.com:", "https://github.com/")


def latest_stable_tag(url: str) -> str | None:
    """Return the highest stable release tag at `url`, or None.

    Lists remote tags, keeps only `_STABLE_TAG_RE` matches (so prereleases
    and non-version tag schemes are ignored), and returns the highest by
    numeric version.
    """
    result = git_query(["git", "ls-remote", "--tags", "--refs", url], cwd=Path.cwd())
    if result.returncode != 0:
        return None
    tags = [
        line.split("refs/tags/", 1)[1]
        for line in result.stdout.splitlines()
        if "refs/tags/" in line
    ]
    stable = [t for t in tags if _STABLE_TAG_RE.match(t)]
    if not stable:
        return None
    return max(stable, key=version_key)


def language_ts_version(root: Path, wrapper: str) -> str | None:
    """Return the tree-sitter version `wrapper` is listed under, or None.

    Scans each `lang/languages-<version>` file for the wrapper name. A
    language appears in exactly one; returns that version string.
    """
    version_files = ug.discover_version_files(root, "languages")
    for version, path in version_files.items():
        if wrapper in ug.read_languages_entries(path):
            return version
    return None


def resolve_target(root: Path, language: str) -> Target:
    """Resolve a `Target` for `language` without mutating anything.

    Dies via update-grammar's `validate_language` on an unknown language.
    """
    valid = ug.discover_valid_languages(root)
    wrapper = ug.validate_language(language, valid)
    submodule = ug.submodule_path(root, language)
    url = gitmodules_url(root, submodule)
    # Languages absent from every languages-* file (e.g. gomod, a "pro"
    # package handled outside the standard version scheme) aren't
    # proposable via this flow; surface that as skip_reason rather than
    # dying, so callers can record it and move on.
    ts_version = language_ts_version(root, wrapper)
    skip_reason = None
    if ts_version is None:
        skip_reason = f"'{wrapper}' is not in any lang/languages-* file"
    tag = latest_stable_tag(url) if url else None
    return Target(
        language=language, wrapper=wrapper, submodule=submodule,
        ts_version=ts_version, url=url, tag=tag, skip_reason=skip_reason,
    )


def submodule_head(submodule: Path) -> str:
    """Return the submodule's current HEAD SHA."""
    return git_query(["git", "rev-parse", "HEAD"], cwd=submodule).stdout.strip()


def recorded_submodule_sha(root: Path, submodule: Path) -> str | None:
    """Return the submodule SHA recorded in the outer repo's index (HEAD).

    Reads the committed gitlink via `git ls-tree` — no submodule checkout
    needed, so this is cheap enough for the enumerate pre-filter.
    """
    rel = submodule.relative_to(root).as_posix()
    out = git_query(["git", "ls-tree", "HEAD", rel], cwd=root).stdout.split()
    return out[2] if len(out) >= 3 else None


def tag_commit_sha(url: str, tag: str) -> str | None:
    """Resolve `tag` to a commit SHA on the remote (peeling annotated tags).

    ls-remote sorts output by refname, so the plain tag ref comes before
    its peeled `^{}` line — and for annotated tags the plain ref is the
    tag OBJECT, which would never match a gitlink commit SHA. Prefer the
    peeled line; lightweight tags have no peeled line, so fall back.
    """
    out = git_query(
        ["git", "ls-remote", url, f"refs/tags/{tag}^{{}}", f"refs/tags/{tag}"],
        cwd=Path.cwd(),
    ).stdout
    peeled = plain = None
    for line in out.splitlines():
        parts = line.split()
        if len(parts) != 2:
            continue
        sha, ref = parts
        if ref.endswith("^{}"):
            peeled = sha
        else:
            plain = sha
    return peeled or plain


def is_up_to_date(root: Path, language: str) -> bool | None:
    """True if `language`'s submodule is already at its latest stable tag.

    Cheap: reads the recorded gitlink + a remote ls-remote, no build/checkout.
    Returns None if it can't be determined (no tag / no url) so callers can
    fall back to attempting the bump rather than wrongly skipping.
    """
    target = resolve_target(root, language)
    if target.skip_reason or target.tag is None or not target.url:
        return None
    cur = recorded_submodule_sha(root, target.submodule)
    tag_sha = tag_commit_sha(target.url, target.tag)
    if cur is None or tag_sha is None:
        return None
    return cur == tag_sha


def wrapper_dir(root: Path, wrapper: str) -> Path:
    """Return the semgrep-<wrapper> directory under semgrep-grammars/src."""
    return root / "lang" / "semgrep-grammars" / "src" / f"semgrep-{wrapper}"


def run_update_grammar(language: str, ts_version: str, tag: str,
                       root: Path) -> subprocess.CompletedProcess:
    """Bump `language` to `tag` via `update-grammar --skip-release`.

    Subprocessed (not imported) so a failure is isolated from this
    process and so we capture its combined output for the PR body / log.
    --skip-release guarantees nothing is pushed to semgrep-<lang>.
    """
    return subprocess.run(
        [str(_UPDATE_GRAMMAR_PATH), language, ts_version,
         "--ref", tag, "--skip-release"],
        cwd=root, text=True, capture_output=True, check=False,
    )


def regenerate_snapshots(root: Path, wrapper: str) -> None:
    """Regenerate corpus snapshots for every grammar in the wrapper.

    A grammar bump almost always churns parse trees, so the committed
    corpus snapshots go stale. `tree-sitter test --update` rewrites them
    from the new parser. Runs in each dir containing a grammar.js (the
    base grammar plus any sub-grammars). Requires core/tree-sitter/bin on
    PATH (the workflow guarantees this). `:error` tests are left untouched
    by --update; if any still fail, the later test-lang re-run catches it.
    """
    wrapper_path = wrapper_dir(root, wrapper)
    grammar_dirs = {p.parent for p in wrapper_path.rglob("grammar.js")}
    for gdir in sorted(grammar_dirs):
        # check=False: --update exits non-zero on :error tests it can't
        # update; that's expected and handled by the authoritative
        # test-lang re-run.
        git_query(["tree-sitter", "test", "--update"], cwd=gdir)


def corpus_diff(root: Path, wrapper: str) -> str:
    """Return the working-tree diff of the wrapper's corpus snapshots."""
    return git_query(
        ["git", "diff", "--", str(wrapper_dir(root, wrapper) / "test" / "corpus")],
        cwd=root,
    ).stdout


def run_test_lang(language: str, root: Path) -> subprocess.CompletedProcess:
    """Run `./test-lang <language>` for the authoritative pass/fail."""
    return subprocess.run(
        ["./test-lang", language], cwd=root / "lang",
        text=True, capture_output=True, check=False,
    )


def reset_language_state(root: Path, submodule: Path, old_sha: str) -> None:
    """Undo every mutation, so a failure never leaks into the next run.

    Mirrors what `update-grammar` leaves behind on a failed run: a
    detached/bumped submodule, edited languages-* files, deleted/regenerated
    parser.c, and regenerated snapshots. Restores the submodule to
    `old_sha` and the outer tree to HEAD.
    """
    git_query(["git", "restore", "--staged", "."], cwd=root)
    git_query(["git", "checkout", "--", "lang"], cwd=root)
    git_query(["git", "checkout", old_sha], cwd=submodule)
    git_query(["git", "checkout", "--", "."], cwd=submodule)
    git_query(["git", "clean", "-fdq"], cwd=submodule)


def tail(text: str, lines: int = 40) -> str:
    """Return the last `lines` lines of `text`."""
    return "\n".join(text.splitlines()[-lines:])


def base_branch() -> str:
    """Branch the grammar-update PR is opened against / forked from.

    The grammar bump must sit on a CLEAN base (just the bump), not on
    whatever branch CI happens to be checked out on. Defaults to `main`;
    override with GRAMMAR_BASE_BRANCH (e.g. `develop`). Validated so an
    env-injected value can't smuggle git options or ref tricks.
    """
    base = os.environ.get("GRAMMAR_BASE_BRANCH", "main")
    if not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9._/-]*", base):
        ug.die(f"invalid GRAMMAR_BASE_BRANCH: {base!r}")
    return base


def branch_name(language: str, tag: str) -> str:
    """Branch for a lang+tag proposal.

    Keyed on the exact tag (not the CI user) so re-runs on the same
    schedule are idempotent and a new upstream tag yields a new branch.
    """
    return f"grammar-update/{language}/{tag}"


def proposal_exists(root: Path, branch: str) -> bool:
    """True if a branch (local or on origin) already exists for this proposal.

    Cheap pre-check so a re-run doesn't rebuild/re-PR an in-flight update.
    Checks origin (the durable signal) and any local branch.
    """
    remote = git_query(
        ["git", "ls-remote", "--heads", "origin", branch], cwd=root,
    ).stdout.strip()
    if remote:
        return True
    local = git_query(
        ["git", "rev-parse", "--verify", "--quiet", f"refs/heads/{branch}"],
        cwd=root,
    )
    return local.returncode == 0


def existing_proposal(root: Path, target: Target) -> Result | None:
    """Result for an already-proposed lang+tag, or None if there is none.

    Runs before the expensive build so a re-run on an in-flight proposal
    costs seconds, not a full bump/test cycle. open_pr() re-checks right
    before pushing, so the small race window stays covered.
    """
    if target.tag is None:
        return None
    branch = branch_name(target.language, target.tag)
    if not proposal_exists(root, branch):
        return None
    return Result(language=target.language, ts_version=target.ts_version,
                  new_tag=target.tag, status=STATUS_EXISTS, branch=branch,
                  detail=f"branch {branch} already exists")


def compare_url(url: str, old_sha: str, new_tag: str) -> str:
    """GitHub compare link old_sha...new_tag for the upstream repo."""
    base = url.removesuffix(".git")
    return f"{base}/compare/{old_sha}...{new_tag}"


def pr_body(result: Result, url: str) -> str:
    """Build the PR description from a propose() result."""
    old, new, tag = result.old_sha, result.new_sha, result.new_tag
    diff = result.corpus_diff.strip()
    diff_section = (
        f"<details><summary>Corpus snapshot diff</summary>\n\n"
        f"```diff\n{diff}\n```\n</details>"
        if diff else "_No corpus snapshot changes._"
    )
    log_tail = result.test_log_tail.strip()
    log_section = (
        f"<details><summary>test-lang output (tail)</summary>\n\n"
        f"```\n{log_tail}\n```\n</details>"
        if log_tail else ""
    )
    adapted_note = (
        "> ⚠️ **An agent adapted existing tests** for this bump (test-lang "
        "failed on the raw bump, typically a mechanical upstream CST rename). "
        "Scrutinize the test changes in the diff.\n\n"
        if result.tests_adapted else ""
    )
    return (
        f"Automated grammar update for **{result.language}**.\n\n"
        f"- Upstream: {url}\n"
        f"- `{old}` → `{new}` (**{tag}**)\n"
        f"- tree-sitter version: `{result.ts_version}`\n"
        f"- Compare: {compare_url(url, old, tag)}\n\n"
        f"Corpus snapshots were auto-regenerated. **Please review** the parse-tree "
        f"changes below — especially any `:error` (error-recovery) cases, which "
        f"`tree-sitter test --update` does not touch automatically.\n\n"
        f"{adapted_note}"
        f"{diff_section}\n\n{log_section}\n\n"
        f"🤖 Generated with [Claude Code](https://claude.com/claude-code)"
    )


AGENT_ADAPTED_LABEL = "agent-adapted-tests"


def open_pr(root: Path, target: Target, result: Result,
            dry_run: bool) -> Result:
    """Push the branch propose(keep=True) built and open a PR for it.

    The validated commit already exists on `grammar-update/<lang>/<tag>`
    (created + committed by propose in keep mode) — here we only push it and
    open the PR. Idempotent: skips if a branch already exists upstream.
    """
    language, tag = target.language, result.new_tag
    base = base_branch()
    branch = result.branch or branch_name(language, tag)
    result.branch = branch
    title = f"Update tree-sitter-{language} grammar to {tag}"
    body = pr_body(result, target.url)

    if dry_run:
        log(f"\n=== would push branch: {branch}")
        log(f"=== would create PR (base {base}): {title}\n")
        log(body)  # stderr: stdout must stay JSON-pure for the artifact
        result.status = "dry-run"
        return result

    if proposal_exists(root, branch):
        result.status = STATUS_EXISTS
        result.detail = f"branch {branch} already exists"
        return result

    run_quiet(["git", "push", "origin", branch], cwd=root)
    create = ["gh", "pr", "create", "--title", title, "--body", body,
              "--base", base, "--head", branch]
    # Flag PRs where the skill adapted test expectations so reviewers look closely.
    if result.tests_adapted:
        ensure_label(origin_repo(), AGENT_ADAPTED_LABEL)
        create += ["--label", AGENT_ADAPTED_LABEL]
    run_quiet(create, cwd=root)
    return result


def review_agent_prompt(language: str, wrapper: str, tag: str,
                        test_log: str) -> str:
    """Prompt that drives Marc-André's `fix-semgrep-grammar` skill.

    That skill (`.agents/skills/fix-semgrep-grammar/SKILL.md`, from #619) is
    the purpose-built tool for repairing the semgrep extension grammar +
    corpus after an upstream tree-sitter bump: it has its own bounded loop,
    strict edit boundaries, coverage invariant, and machine-readable exit
    statuses (FIX-SEMGREP-GRAMMAR: SUCCESS | CANNOT_PROCEED | ITERATION_LIMIT).
    We invoke it rather than hand-rolling the fix logic; the authoritative
    signal remains the test-lang RE-RUN the caller does afterward.
    """
    return (
        f"Use the `fix-semgrep-grammar` skill to make `test-lang {language}` "
        f"pass. Context: the tree-sitter-{language} submodule was just bumped "
        f"to {tag} and test-lang now fails. Follow the skill's edit boundaries "
        f"and exit contract exactly; do not commit, push, or open a PR — leave "
        f"the working tree changed for the outer pipeline. Print the skill's "
        f"final FIX-SEMGREP-GRAMMAR status line.\n\n"
        f"Failing test-lang output:\n{tail(test_log, 60)}"
    )


def agent_cmd(prompt: str) -> list[str]:
    """Build the Cursor `agent` command for headless CI execution.

    `-p` is print/non-interactive mode; `--force` auto-approves file edits
    and command execution (without it the agent stops at an interactive
    permission prompt and does nothing in CI). `--output-format json` makes
    the result parseable. Model overridable via CURSOR_MODEL.
    """
    cmd = ["agent", "-p", "--force", "--output-format", "json"]
    model = os.environ.get("CURSOR_MODEL")
    if model:
        cmd += ["--model", model]
    cmd.append(prompt)
    # Hard wall-clock bound so a stuck agent session can't burn the whole job
    # (a bounded loop cap the CLI doesn't expose). `timeout` returns 124 on
    # expiry; callers treat a non-zero agent as best-effort. Override via
    # CURSOR_AGENT_TIMEOUT (default 25m, comfortably inside the 45m job cap).
    limit = os.environ.get("CURSOR_AGENT_TIMEOUT", "25m")
    return ["timeout", limit, *cmd]


def run_review_agent(root: Path, language: str, wrapper: str, tag: str,
                     test_log: str) -> None:
    """Invoke the Cursor agent to review + adapt tests for a failing bump.

    Runs in-repo (cwd = root). Output to stderr to keep stdout JSON-pure.
    Best-effort: the authoritative signal is the test-lang RE-RUN the
    caller does afterward, so we don't raise on the agent's own exit code.
    """
    prompt = review_agent_prompt(language, wrapper, tag, test_log)
    log(f"$ agent -p --force <review prompt for {language}>  (in {root})")
    r = subprocess.run(agent_cmd(prompt), cwd=root, text=True,
                       capture_output=True, check=False)
    sys.stderr.write(r.stdout)
    sys.stderr.write(r.stderr)


def propose(root: Path, target: Target, keep: bool = False,
            review_agent: bool = False) -> Result:
    """Run the full single-language propose flow; return a Result.

    Bumps to the latest tag, regenerates snapshots, runs test-lang, and
    classifies the outcome. On a test-lang failure, `review_agent=True`
    dispatches the fix-semgrep-grammar skill to adapt the tests, then
    test-lang is re-run (the authoritative signal); with the default
    `review_agent=False` the failure is reported as-is — no Cursor agent is
    ever launched unless the caller opted in. With `keep=True`, the work is
    done on the grammar-update branch (forked from origin/main) and the
    validated tree is committed there for open_pr() to push — no re-bump,
    no second agent run. With keep=False (classify-only), the working tree
    is reset before returning.
    Does NOT create a PR — that's the caller's job under --open-pr.
    """
    language = target.language
    tag = target.tag
    wrapper = target.wrapper
    result = Result(language=language, ts_version=target.ts_version, new_tag=tag)

    if target.skip_reason:
        result.status = STATUS_NO_TAGS
        result.detail = target.skip_reason
        return result
    if tag is None:
        result.status = STATUS_NO_TAGS
        result.detail = "no stable release tag upstream"
        return result

    submodule = target.submodule
    old_sha = submodule_head(submodule)
    result.old_sha = old_sha

    # In `keep` (PR) mode, do all the work directly on the grammar-update
    # branch forked from origin/main, and DON'T reset — the validated tree
    # becomes the PR commit (open_pr just pushes it). In classify-only mode,
    # do the work in place and reset the tree before returning. Doing it once,
    # on the final branch, avoids the old propose-resets/open_pr-redoes
    # duplication (and the second, unvalidated agent run it caused).
    branch = branch_name(language, tag)
    committed = False
    if keep:
        base = base_branch()
        run_quiet(["git", "fetch", "origin", base], cwd=root)
        run_quiet(["git", "checkout", "-B", branch, f"origin/{base}"], cwd=root)

    try:
        # A non-zero bump with a MOVED submodule is expected (update-grammar's
        # own final test-lang fails on the stale snapshots we regenerate next);
        # our re-run below is the authoritative signal. But an unchanged
        # submodule is only a real no-op if the bump itself succeeded —
        # otherwise it failed before doing anything and must be surfaced.
        bump = run_update_grammar(language, target.ts_version, tag, root)
        new_sha = submodule_head(submodule)
        result.new_sha = new_sha

        if new_sha == old_sha:
            if bump.returncode != 0:
                result.status = STATUS_FAILED
                result.detail = "update-grammar failed"
                result.test_log_tail = tail(bump.stdout + bump.stderr)
                return result
            result.status = STATUS_NO_OP
            return result

        # Snapshots are expected to churn; regenerate then test for the
        # authoritative result.
        regenerate_snapshots(root, wrapper)
        result.corpus_diff = corpus_diff(root, wrapper)
        test = run_test_lang(language, root)
        result.test_log_tail = tail(test.stdout + test.stderr)

        if test.returncode != 0 and review_agent:
            # test-lang failed — most often a mechanical upstream CST rename
            # that broke existing corpus snapshots. Invoke the fix-semgrep-
            # grammar skill to adapt the tests, then re-test as the
            # authoritative signal (the skill's own status is advisory).
            run_review_agent(root, language, wrapper, tag,
                             test.stdout + test.stderr)
            result.corpus_diff = corpus_diff(root, wrapper)
            test = run_test_lang(language, root)
            result.test_log_tail = tail(test.stdout + test.stderr)
            if test.returncode == 0:
                result.tests_adapted = True

        if test.returncode != 0:
            result.status = STATUS_FAILED
            result.detail = ("test-lang failed (review agent could not fix it)"
                             if review_agent else
                             "test-lang failed (review agent not enabled)")
            if not result.test_log_tail:
                result.test_log_tail = tail(bump.stdout + bump.stderr)
            return result

        result.status = STATUS_UPDATED
        if keep:
            # Run pre-commit on changed files to fix auto-fixable issues before staging.
            run_quiet(["pre-commit", "run", "--files", "lang/"], cwd=root)
            run_quiet(["git", "add", "-A", "--", ".",
                       ":(exclude)result-*.json", ":(exclude)core"], cwd=root)
            run_quiet(["git", "commit", "-m",
                       f"Update tree-sitter-{language} grammar to {tag}"], cwd=root)
            committed = True
            result.branch = branch
        return result
    finally:
        # Classify-only mode always resets. keep mode resets only if we did
        # NOT land a commit (early return / failure) so a broken branch isn't
        # left checked out; a committed branch is intentionally kept.
        if not (keep and committed):
            reset_language_state(root, submodule, old_sha)


###############################################################################
# Downstream: release to semgrep-<lang> #
###############################################################################


def github_org() -> str:
    """Org owning the semgrep-<dialect> repos, validated as an owner name."""
    org = os.environ.get("GITHUB_ORG", "semgrep")
    if not re.fullmatch(r"[A-Za-z0-9-]+", org):
        ug.die(f"invalid GITHUB_ORG: {org!r}")
    return org


def downstream_repo_exists(dialect: str) -> bool:
    """True if a semgrep-<dialect> repo exists to release into.

    Not every test-lang dialect has its own downstream repo: php fans out
    to [php, php-only] for testing, but only semgrep-php exists (no
    semgrep-php-only); likewise sfapex has no repo (only semgrep-apex).
    Releasing a dialect with no repo would fail, so we filter to the ones
    that exist.
    """
    return git_query(
        ["gh", "repo", "view", f"{github_org()}/semgrep-{dialect}",
         "--json", "name"],
        cwd=Path.cwd(),
    ).returncode == 0


def origin_repo() -> str:
    """Return this repo as owner/name (for gh cross-repo references)."""
    return git_query(
        ["gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"],
        cwd=Path.cwd(),
    ).stdout.strip()


def ensure_label(repo: str, label: str) -> None:
    """Create `label` in `repo` if missing (idempotent; ignores 'exists')."""
    git_query(
        ["gh", "label", "create", label, "--repo", repo,
         "--color", "B60205", "--description",
         "An agent adapted test expectations for this grammar bump",
         "--force"],
        cwd=Path.cwd(),
    )


def release_dialects(language: str, wrapper: str) -> list[str]:
    """Dialects to release for a language, filtered to existing repos.

    `lang/release` operates per dialect (typescript -> [typescript, tsx],
    php -> [php, php-only]), but only dialects with a real
    semgrep-<dialect> repo can be released. Falls back to the language
    itself.
    """
    dialects = ug.LANGUAGE_VARIANTS.get(wrapper, [language])
    existing = [d for d in dialects if downstream_repo_exists(d)]
    return existing or [language]


def open_downstream_pr(dialect: str, branch: str, tag: str,
                       *, dry_run: bool) -> None:
    """Open a PR on semgrep-<dialect> for the released branch (idempotent).

    The default branch is protected (requires PRs), so the generated-parser
    change lands via review, not a dangling branch. Skips if a PR for the
    branch already exists.
    """
    repo = f"{github_org()}/semgrep-{dialect}"
    if dry_run:
        log(f"[dry run] would open PR on {repo} for {branch}")
        return
    existing = git_query(
        ["gh", "pr", "list", "--repo", repo, "--head", branch,
         "--state", "all", "--json", "number", "-q", ".[0].number"],
        cwd=Path.cwd(),
    ).stdout.strip()
    if existing:
        log(f"{repo}: PR already exists for {branch} (#{existing})")
        return
    title = f"Update generated {dialect} parser for {tag}"
    body = ("Automated: regenerated parser from the tree-sitter-"
            f"{dialect} {tag} grammar bump.\n\n"
            "🤖 Generated with [Claude Code](https://claude.com/claude-code)")
    run_quiet(
        ["gh", "pr", "create", "--repo", repo, "--head", branch,
         "--title", title, "--body", body],
        cwd=Path.cwd(),
    )


def release_downstream(root: Path, language: str, wrapper: str, branch: str,
                       tag: str, *, dry_run: bool) -> subprocess.CompletedProcess:
    """Release the generated parser to each semgrep-<dialect> repo, via PR.

    For each dialect: `lang/release <dialect> --branch <branch>` pushes the
    generated parser to that branch, then open a PR (branch -> default) so
    it merges through review — the default branch is PR-protected, so a
    direct push isn't possible anyway. This is the only step that touches
    the downstream repos, gated behind --release, --dry-run safe.
    """
    lang_dir = root / "lang"
    last = None
    for dialect in release_dialects(language, wrapper):
        cmd = ["./release", dialect, "--branch", branch]
        if dry_run:
            cmd.append("--dry-run")
        log(f"$ {' '.join(cmd)}  (in {lang_dir})")
        # Capture (don't inherit) so release's verbose output goes to our
        # log/stderr and never pollutes the JSON we print to stdout.
        last = subprocess.run(
            cmd, cwd=lang_dir, text=True, capture_output=True, check=False,
        )
        sys.stderr.write(last.stdout)
        sys.stderr.write(last.stderr)
        if last.returncode != 0:
            return last
        open_downstream_pr(dialect, branch, tag, dry_run=dry_run)
    return last  # type: ignore[return-value]


###############################################################################
# Entry point #
###############################################################################


def list_languages(root: Path, as_json: bool, updatable_only: bool = False) -> None:
    """Print proposable languages (sorted).

    With `updatable_only`, emit only languages whose recorded submodule SHA
    differs from their latest stable tag — the cheap pre-filter that keeps
    up-to-date languages out of the expensive build matrix entirely.
    Languages whose status can't be cheaply determined are INCLUDED (so the
    full flow decides, rather than wrongly skipping them).
    """
    names = sorted(ug.discover_valid_languages(root))
    if updatable_only:
        kept = []
        for name in names:
            up = is_up_to_date(root, name)
            if up is True:
                log(f"skip {name}: already at latest tag")
            else:
                kept.append(name)
        names = kept
    if as_json:
        print(json.dumps(names))
    else:
        print("\n".join(names))


def summarize(results_dir: Path) -> None:
    """Render a markdown table from per-language result JSON files.

    Reads every `*.json` under `results_dir` (the workflow's downloaded
    artifacts) and emits a GitHub-flavored summary grouped by status, so
    failures and no-tags languages are visible on the run without opening
    each job.
    """
    rows = []
    for path in sorted(results_dir.rglob("*.json")):
        try:
            r = json.loads(path.read_text())
        except (json.JSONDecodeError, OSError):
            continue
        rows.append(r)

    by_status: dict[str, list[dict[str, Any]]] = {}
    for r in rows:
        by_status.setdefault(r.get("status", "unknown"), []).append(r)

    order = [STATUS_UPDATED, STATUS_EXISTS, STATUS_NO_OP, STATUS_NO_TAGS, STATUS_FAILED]
    icon = {STATUS_UPDATED: "✅", STATUS_EXISTS: "↩️", STATUS_NO_OP: "➖",
            STATUS_NO_TAGS: "🏷️", STATUS_FAILED: "❌"}

    print("## Grammar update proposals\n")
    print("| Language | Status | Detail |")
    print("|---|---|---|")
    for status in order + [s for s in by_status if s not in order]:
        for r in sorted(by_status.get(status, []), key=lambda x: x["language"]):
            detail = r.get("detail") or (
                f"{(r.get('old_sha') or '')[:8]} → {r.get('new_tag') or ''}"
                if status == STATUS_UPDATED else ""
            )
            print(f"| {r['language']} | {icon.get(status, '')} {status} | {detail} |")


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    """Parse CLI args."""
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("language", nargs="?", help="Language to propose an update for.")
    parser.add_argument(
        "--list-languages", action="store_true",
        help="Print the set of proposable languages and exit.",
    )
    parser.add_argument(
        "--updatable-only", action="store_true",
        help="With --list-languages, emit only languages whose submodule is "
             "behind its latest stable tag (cheap pre-filter; skips the build "
             "matrix for up-to-date languages).",
    )
    parser.add_argument(
        "--summarize", metavar="DIR",
        help="Render a markdown summary from result JSON files under DIR.",
    )
    parser.add_argument(
        "--json", action="store_true",
        help="With --list-languages, emit a JSON array.",
    )
    parser.add_argument(
        "--resolve-tag-only", action="store_true",
        help="Print the latest stable tag for the language and exit.",
    )
    parser.add_argument(
        "--open-pr", action="store_true",
        help="Create the PR (default: dry run, emit JSON result only).",
    )
    parser.add_argument(
        "--dry-run", action="store_true",
        help="Print would-be PR / release actions instead of running them.",
    )
    parser.add_argument(
        "--review-agent", action="store_true",
        help="On test-lang failure, dispatch a Cursor agent (the "
             "fix-semgrep-grammar skill) to adapt the extension grammar/tests, "
             "then re-run test-lang. OFF by default: sends grammar source and "
             "test logs to Cursor, so it must be explicitly opted into "
             "(needs CURSOR_API_KEY).",
    )
    parser.add_argument(
        "--release", action="store_true",
        help="Downstream step: push the generated parser to the "
             "grammar-update/<lang>/<tag> branch on semgrep-<lang> and open a "
             "PR there. Run this AFTER the this-repo PR branch exists. Needs "
             "downstream push creds. (semgrep-proprietary integration is "
             "deliberately NOT handled here — that stays with the existing "
             "Cursor workflow on that repo.)",
    )
    parser.add_argument(
        "--result", metavar="FILE",
        help="With --release, read the validated tag/branch from this "
             "result-<lang>.json artifact (written by the propose job) "
             "instead of re-resolving the tag live — guarantees the release "
             "matches what test-lang validated.",
    )
    return parser.parse_args(argv)


def run_release(root: Path, target: Target, dry_run: bool,
                result_file: str | None = None) -> int:
    """Downstream hand-off: release the validated parser to semgrep-<lang>.

    Checks out the grammar-update/<lang>/<tag> branch the propose job built
    and validated (rather than re-bumping) and releases its generated parser
    to the same branch on semgrep-<lang> via PR. With `result_file`, the
    tag/branch come from the propose job's result artifact — the exact ones
    test-lang validated; without it (manual runs) the tag is re-resolved
    live, and a stale branch name fails loudly on the fetch (no silent
    wrong-version release).
    """
    language, wrapper = target.language, target.wrapper
    if result_file:
        res = Result.from_file(Path(result_file))
        tag = res.new_tag
        branch = res.branch or (branch_name(language, tag) if tag else None)
    else:
        tag = target.tag
        branch = branch_name(language, tag) if tag else None
    if tag is None or branch is None:
        ug.die(f"{language}: no validated tag/branch; nothing to release.")

    # Check out the exact branch the propose job built + validated (submodule
    # bump + any skill-adapted tests are committed there). Do NOT re-bump —
    # that could pull different content than what test-lang actually
    # validated. `lang/release` regenerates the OCaml sources from this tree
    # via its own `make gen`.
    run_quiet(["git", "fetch", "origin", branch], cwd=root)
    run_quiet(["git", "checkout", branch], cwd=root)
    run_quiet(["git", "submodule", "update", "--init", "--recursive", "--depth", "1",
               "--", str(target.submodule.relative_to(root))], cwd=root)

    rel = release_downstream(root, language, wrapper, branch, tag, dry_run=dry_run)
    if rel is not None and rel.returncode != 0:
        ug.die(f"{language}: lang/release failed.")

    log(f"{language}: released to semgrep-{wrapper} branch {branch} "
        f"(PR opened per dialect).")
    print(json.dumps({"language": language, "new_tag": tag,
                      "branch": branch, "released": not dry_run}))
    return 0


def main() -> int:
    """Drive a single-language proposal; see module docstring."""
    root = ug.repo_root()
    args = parse_args()

    if args.list_languages:
        list_languages(root, args.json, updatable_only=args.updatable_only)
        return 0

    if args.summarize:
        summarize(Path(args.summarize))
        return 0

    if not args.language:
        ug.die("a language is required (or use --list-languages).")

    target = resolve_target(root, args.language)

    if args.resolve_tag_only:
        if target.tag is None:
            log(f"{args.language}: no stable release tag found.")
            return 1
        print(target.tag)
        return 0

    if args.release:
        return run_release(root, target, args.dry_run, result_file=args.result)

    # keep=True (do the work on the PR branch, commit it) only for a real
    # --open-pr run; --dry-run and classify-only leave the tree reset.
    # In keep mode, bail cheaply if this lang+tag was already proposed
    # (dry runs still exercise the full pipeline on purpose).
    keep = args.open_pr and not args.dry_run
    result = existing_proposal(root, target) if keep else None
    if result is None:
        result = propose(root, target, keep=keep, review_agent=args.review_agent)

    # Only a green, real update is worth a PR. Everything else (no-op,
    # no-tags, failed) is reported as-is for the workflow summary.
    if (args.open_pr or args.dry_run) and result.status == STATUS_UPDATED:
        result = open_pr(root, target, result, dry_run=args.dry_run)

    print(result.to_json())
    return 0 if result.status != STATUS_FAILED else 1


def cli() -> None:
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    cli()
