{
  "grammars": [
    {
      "name": "python",
      "camelcase": "Python",
      "scope": "source.python",
      "path": ".",
      "file-types": ["py"],
      "injection-regex": "py"
    }
  ],
  "metadata": {
    "version": "0.25.0",
    "license": "MIT",
    "description": "Semgrep-extended Python grammar for tree-sitter",
    "authors": [{ "name": "Semgrep" }],
    "links": {
      "repository": "https://github.com/semgrep/ocaml-tree-sitter-semgrep"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
