#!/usr/bin/env python3
#
# Print, one per line, the distinct tree-sitter versions the grammars are
# pinned to. The set is derived from the lang/languages-<version> and
# lang/language-variants-<version> filenames -- the single source of truth for
# which tree-sitter versions this repo uses. Nothing is hardcoded.
#
# Usage: ts-versions
#
from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from ts_versions import list_pinned_versions  # noqa: E402


def main() -> int:
    """Print each pinned tree-sitter version on its own line."""
    argparse.ArgumentParser(
        description="Print each pinned tree-sitter version on its own line."
    ).parse_args()
    for version in list_pinned_versions():
        print(version)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
