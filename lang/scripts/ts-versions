#!/usr/bin/env python3
#
# Print, one per line, the distinct tree-sitter versions the grammars are
# pinned to. The set is derived from the lang/languages-<version> and
# lang/language-variants-<version> filenames -- the single source of truth for
# which tree-sitter versions this repo uses. Nothing is hardcoded.
#
from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from ts_versions import main_ts_versions  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main_ts_versions())
