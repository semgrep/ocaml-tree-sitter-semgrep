#!/usr/bin/env python3
#
# Print the tree-sitter version that should be used to build a given
# language or grammar.
#
# The mapping lives in lang/languages-<version> files: a name listed in
# lang/languages-0.22.6 means "build this with tree-sitter 0.22.6", etc.
# Exits non-zero with an error message if the name is not listed.
#
# Usage: ts-version-for-lang <lang>
#
from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from ts_versions import TsVersionError, version_for_lang  # noqa: E402


def main() -> int:
    """Print the tree-sitter version pinned for a language or dialect name."""
    parser = argparse.ArgumentParser(
        description="Print the tree-sitter version pinned for a language name."
    )
    parser.add_argument("lang", help="language or dialect name")
    args = parser.parse_args()
    try:
        print(version_for_lang(args.lang))
    except TsVersionError as exc:
        print(exc, file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
