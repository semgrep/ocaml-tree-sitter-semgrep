#!/usr/bin/env python3
#
# Print the tree-sitter version that should be used to build a given
# language or grammar.
#
# The mapping lives in lang/languages-<version> files: a name listed in
# lang/languages-0.22.6 means "build this with tree-sitter 0.22.6", etc.
# Exits non-zero with an error message if the name is not listed.
#
from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from ts_versions import main_ts_version_for_lang  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main_ts_version_for_lang())
