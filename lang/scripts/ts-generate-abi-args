#!/usr/bin/env python3
#
# Print the 'tree-sitter generate' ABI argument(s) for a grammar, honoring the
# SEMGREP_ENABLE_ABI15 environment variable. See lang/generate_abi_args.py.
#
# Usage: ts-generate-abi-args <grammar-dir> <tree-sitter-version>
#
from __future__ import annotations

import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from generate_abi_args import main_ts_generate_abi_args  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main_ts_generate_abi_args())
