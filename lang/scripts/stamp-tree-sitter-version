#!/usr/bin/env bash
#
# Stamp a generated tree-sitter parser.c with a greppable provenance comment
# recording the tree-sitter version that produced it.
#
# tree-sitter does not embed its own semver in generated code (only the ABI
# version, via the LANGUAGE_VERSION macro). We capture it here from the
# 'tree-sitter' binary on PATH, which the calling Makefile (lang/Makefile.common)
# has pinned to this language's tree-sitter version.
#
# The comment is added as the first line, e.g.:
#   // semgrep: generated by tree-sitter 0.26.3 (b40f342067a89cd6331bf4c27407588320f3c263)
#
# Idempotent: any existing stamp is replaced rather than duplicated, so it is
# safe to run more than once on the same file.
#
# Usage: stamp-tree-sitter-version <path/to/parser.c>
set -eu

# coupling: lang/release reads this exact prefix back out of the parser to
# populate fyi/tree-sitter-version.
marker='// semgrep: generated by '

if [[ $# -ne 1 ]]; then
  echo "Usage: $(basename "$0") <parser.c>" >&2
  exit 1
fi

parser_c=$1
if [[ ! -f "$parser_c" ]]; then
  echo "Error: no such file: $parser_c" >&2
  exit 1
fi

if ! version=$(tree-sitter --version); then
  echo "Error: 'tree-sitter --version' failed (is tree-sitter on PATH?)." >&2
  exit 1
fi

tmp=$(mktemp "$parser_c.XXXXXX")
{
  echo "$marker$version"
  # Drop any stamp from a previous run, then keep the rest of the parser.
  sed '\#^// semgrep: generated by #d' "$parser_c"
} > "$tmp"
mv "$tmp" "$parser_c"
