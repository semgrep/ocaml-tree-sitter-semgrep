#! /usr/bin/env bash
#
# Verify that each grammar is generated with the tree-sitter version specified
# for it in lang/languages-<version> / lang/language-variants-<version>.
#
# Three layers:
#   1. Resolution: ts-version-for-lang returns exactly the version each name is
#      listed under (no name in two version files), and every language the build
#      knows about (SUPPORTED_TS_LANGUAGES / SUPPORTED_DIALECTS) resolves.
#   2. Binary identity: every grammar directory resolves to a declared version,
#      and the installed core/tree-sitter-<version>/bin/tree-sitter actually
#      reports that version -- so when the build picks that directory, it really
#      runs that version.
#   3. End to end: building a grammar pinned to version V actually generates it
#      with V (the build reports "(tree-sitter V)" and re-generates parser.c).
#
set -uo pipefail

script_dir=$(cd "$(dirname "$0")" && pwd)
lang_dir=$(cd "$script_dir/.." && pwd)
repo_root=$(cd "$lang_dir/.." && pwd)
ts_for_lang="$script_dir/ts-version-for-lang"
ts_for_dir="$script_dir/ts-version-for-grammar-dir"

fail=0
ok()   { echo "  ok: $*"; }
bad()  { echo "  FAIL: $*" >&2; fail=1; }
note() { echo "  note: $*"; }

#------------------------------------------------------------------------------
echo "== Layer 1: resolution is correct, unique, and complete =="

# Build the expected name -> version map directly from the list files, and
# detect any name that appears under two different versions.
declare -A want
dup=0
for f in "$lang_dir"/languages-* "$lang_dir"/language-variants-*; do
  case "$f" in *.readme) continue ;; esac
  [ -f "$f" ] || continue
  v=$(basename "$f" | sed -E 's/^(languages|language-variants)-//')
  while read -r name; do
    [ -n "$name" ] || continue
    if [ -n "${want[$name]:-}" ] && [ "${want[$name]}" != "$v" ]; then
      bad "'$name' is listed under both ${want[$name]} and $v"
      dup=1
    fi
    want[$name]="$v"
  done < "$f"
done
[ "$dup" -eq 0 ] && ok "no language is listed under two tree-sitter versions"

# ts-version-for-lang must agree with the map for every listed name.
mismatch=0
for name in "${!want[@]}"; do
  got=$("$ts_for_lang" "$name" 2>/dev/null)
  [ "$got" = "${want[$name]}" ] || { bad "ts-version-for-lang $name = '$got', expected '${want[$name]}'"; mismatch=1; }
done
[ "$mismatch" -eq 0 ] && ok "ts-version-for-lang agrees with the list files for all ${#want[@]} names"

# Every language/dialect the build iterates over must resolve.
supported=$(awk '
  /^(SUPPORTED_TS_LANGUAGES|SUPPORTED_DIALECTS)[ \t]*=/ { collect=1 }
  collect {
    line=$0
    sub(/^[A-Z_]+[ \t]*=/, "", line); sub(/\\$/, "", line); sub(/#.*/, "", line)
    n=split(line, a, /[ \t]+/); for (i=1;i<=n;i++) if (a[i]!="") print a[i]
    if ($0 !~ /\\$/) collect=0
  }' "$lang_dir/Makefile" | sort -u)
missing=""
for name in $supported; do
  "$ts_for_lang" "$name" >/dev/null 2>&1 || missing="$missing $name"
done
if [ -z "$missing" ]; then
  ok "every SUPPORTED_TS_LANGUAGES/SUPPORTED_DIALECTS entry resolves to a version ($(echo "$supported" | wc -w | tr -d ' ') names)"
else
  bad "these supported languages resolve to no version:$missing"
fi

#------------------------------------------------------------------------------
echo "== Layer 2: each grammar dir resolves to a declared version whose binary matches =="

declared_versions=$(printf '%s\n' "${want[@]}" | sort -u)
is_declared() { printf '%s\n' "$declared_versions" | grep -qx "$1"; }

# Cache binary-version checks per version.
declare -A bin_checked
check_binary() { # check_binary <version>
  local v="$1" bin actual
  [ -n "${bin_checked[$v]:-}" ] && return 0
  bin_checked[$v]=1
  bin="$repo_root/core/tree-sitter-$v/bin/tree-sitter"
  if [ ! -x "$bin" ]; then
    note "tree-sitter $v not installed ($bin) -- skipping its binary-identity check"
    return 0
  fi
  actual=$("$bin" --version | sed -E 's/^tree-sitter ([0-9.]+).*/\1/')
  if [ "$actual" = "$v" ]; then
    ok "core/tree-sitter-$v/bin/tree-sitter reports $actual"
  else
    bad "core/tree-sitter-$v/bin/tree-sitter reports $actual, expected $v"
  fi
}

# Only the semgrep-* packages are generated by this pipeline (see
# semgrep-grammars/src/Makefile: "for pkg in semgrep-*"). Upstream tree-sitter-*
# submodules are inputs, not generated here, so they are not scanned.
is_supported() { printf '%s\n' "$supported" | grep -qx "$1"; }

grammar_dirs=$(cd "$lang_dir/semgrep-grammars/src" && \
  for pkg in semgrep-*; do find "$pkg" -name grammar.js; done | xargs -I{} dirname {} | sort)
bad_dirs=0; checked=0
for d in $grammar_dirs; do
  full="$lang_dir/semgrep-grammars/src/$d"
  if ! v=$("$ts_for_dir" "$full" 2>/dev/null); then
    base=${d%%/*}; base=${base#semgrep-}
    if is_supported "$base"; then
      bad "grammar dir $d resolves to no version, but '$base' is a supported language"
      bad_dirs=1
    else
      note "$d resolves to no version ('$base' is not in SUPPORTED_TS_LANGUAGES); a full 'make -C semgrep-grammars/src build' would fail on it"
    fi
    continue
  fi
  if ! is_declared "$v"; then bad "grammar dir $d resolved to undeclared version '$v'"; bad_dirs=1; continue; fi
  check_binary "$v"
  checked=$((checked + 1))
done
[ "$bad_dirs" -eq 0 ] && ok "all $checked generated grammar dirs resolve to a declared tree-sitter version"

#------------------------------------------------------------------------------
echo "== Layer 3: building a grammar actually generates it with its version =="

# One representative grammar per version (first found whose sources + binary are
# present). Builds it and asserts the build reports that exact version.
declare -A e2e_pkg
for d in $grammar_dirs; do
  top=${d%%/*}                                  # e.g. semgrep-php from semgrep-php/php
  pkg="$lang_dir/semgrep-grammars/src/$top"
  v=$("$ts_for_dir" "$lang_dir/semgrep-grammars/src/$d" 2>/dev/null) || continue
  [ -n "${e2e_pkg[$v]:-}" ] && continue
  [ -x "$repo_root/core/tree-sitter-$v/bin/tree-sitter" ] || continue
  [ -f "$pkg/grammar.js" ] || continue
  e2e_pkg[$v]="$top"
done

if ! command -v node >/dev/null 2>&1; then
  note "node not found -- skipping Layer 3 (generation needs node)"
elif [ "${#e2e_pkg[@]}" -eq 0 ]; then
  note "no buildable grammar found for any installed version -- skipping Layer 3"
else
  for v in $(printf '%s\n' "${!e2e_pkg[@]}" | sort); do
    pkg="${e2e_pkg[$v]}"
    pdir="$lang_dir/semgrep-grammars/src/$pkg"
    echo "  building $pkg (expected tree-sitter $v)"
    find "$pdir" -name grammar.js -exec touch {} +   # force regeneration
    out=$(make -C "$pdir" build 2>&1)
    rc=$?
    reported=$(printf '%s\n' "$out" | sed -nE 's/.*\(tree-sitter ([0-9.]+)\).*/\1/p' | sort -u)
    wrong=$(printf '%s\n' "$reported" | grep -vx "$v" | grep -v '^$' || true)
    if [ -n "$wrong" ]; then
      # A wrong version is a real failure regardless of build success.
      bad "$pkg was generated with tree-sitter version(s) [$(echo $wrong)], expected $v"
    elif [ $rc -eq 0 ] && printf '%s\n' "$reported" | grep -qx "$v"; then
      ok "$pkg generated with tree-sitter $v"
    else
      note "$pkg build did not complete (rc=$rc), can't fully verify -- likely missing submodule sources; skipping"
      printf '%s\n' "$out" | tail -3 | sed 's/^/      /'
    fi
  done
fi

#------------------------------------------------------------------------------
echo
if [ "$fail" -eq 0 ]; then
  echo "All grammar tree-sitter-version checks passed."
else
  echo "Grammar tree-sitter-version checks FAILED." >&2
fi
exit "$fail"
